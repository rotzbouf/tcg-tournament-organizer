{
  "name": "tcg-tournament-organizer",
  "version": "0.6.0",
  "description": "Desktop app for organizing TCG tournaments using the Swiss system",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": ["tcg", "tournament", "swiss-system", "electron"],
  "author": {
    "name": "rotzbouf",
    "email": "rotzbouf@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "clsx": "^2.1.1",
    "i18next": "^23.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^6.30.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^1.6.0"
  }
}
